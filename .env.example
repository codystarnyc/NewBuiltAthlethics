PORT=3001
NODE_ENV=development

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_UPLOADS=built-athletics-uploads
S3_BUCKET_PROCESSED=built-athletics-processed

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/built_athletics

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# OpenAI (fallback provider)
OPENAI_API_KEY=

# Google Gemini (primary vision + text provider)
GEMINI_API_KEY=

# Vision provider: "gemini" (default) or "openai" for rollback
VISION_PROVIDER=gemini

# Edamam Nutrition API (Core tier)
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# BackendMaster base URL (Java Play backend)
BACKEND_MASTER_URL=https://builtathletix.com

# Fitness On Demand (fod247.io) — set on EB: eb setenv KEY=value ...
# Never expose CLIENT_SECRET in frontend bundles; API reads these server-side.
# Token: POST {REACT_APP_FITNESS_OD_MURL}/auth/token
# JSON body: {"clientId":"...","clientSecret":"...","grantType":"client_credentials"}
# Test locally: npm run test:fod
REACT_APP_FITNESS_OD_URL=https://api.fod247.io/flex/v1
REACT_APP_FITNESS_OD_MURL=https://api.fod247.io/management/v1
REACT_APP_FITNESS_OD_CLIENT_ID=
REACT_APP_FITNESS_OD_CLIENT_SECRET=
REACT_APP_FITNESS_ADMIN_EMAIL=admin@builtathletics.com
