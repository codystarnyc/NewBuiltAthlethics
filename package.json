{
  "name": "built-athletics-api",
  "version": "3.0.0",
  "description": "Unified backend API for Built Athletics — auth, user, exercise, food, meal plans, rewards, health, and AI image processing",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && mkdir -p dist/admin && cp src/admin/index.html dist/admin/",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test:fod": "tsx scripts/test-fod-connection.ts",
    "trello": "tsx scripts/trello-cli.ts",
    "trello:export": "tsx scripts/trello-cli.ts list",
    "trello:sync": "tsx scripts/trello-cli.ts sync",
    "trello:complete": "tsx scripts/trello-cli.ts complete"
  },
  "keywords": [
    "fitness",
    "nutrition",
    "ai",
    "image-processing"
  ],
  "license": "ISC",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "openai": "^6.33.0",
    "prisma": "^6.19.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
